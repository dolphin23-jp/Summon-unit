{
  "name": "summon-unit",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "packageManager": "pnpm@10.13.1",
  "engines": {
    "node": "22.x"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "demo:headless": "tsc -p tsconfig.headless.json && node -e \"require('fs').writeFileSync('.headless-dist/package.json', '{\\\"type\\\":\\\"commonjs\\\"}')\" && node .headless-dist/scripts/headless-battle-demo.js && node -e \"require('fs').rmSync('.headless-dist', { recursive: true, force: true })\""
  },
  "dependencies": {
    "react": "18.3.1",
    "react-dom": "18.3.1"
  },
  "devDependencies": {
    "@eslint/js": "9.39.5",
    "@types/react": "18.3.31",
    "@types/react-dom": "18.3.7",
    "@vitejs/plugin-react": "4.7.0",
    "eslint": "9.39.5",
    "eslint-plugin-react-hooks": "5.2.0",
    "eslint-plugin-react-refresh": "0.4.26",
    "globals": "15.15.0",
    "prettier": "3.9.5",
    "typescript": "5.7.3",
    "typescript-eslint": "8.64.0",
    "vite": "6.4.3",
    "vitest": "3.2.7"
  }
}
