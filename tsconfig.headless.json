{
  "compilerOptions": {
    "target": "ES2022",
    "module": "CommonJS",
    "moduleResolution": "Node",
    "rootDir": ".",
    "outDir": ".headless-dist",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true
  },
  "include": [
    "scripts/headless-battle-demo.ts",
    "scripts/ai-regression-benchmark.ts",
    "scripts/vertical-slice-balance.ts",
    "scripts/validate-content.ts",
    "src/ai/**/*.ts",
    "src/balance/**/*.ts",
    "src/battle/**/*.ts",
    "src/content/**/*.ts",
    "src/demo/**/*.ts",
    "src/progression/**/*.ts"
  ],
  "exclude": ["**/*.test.ts", "src/**/*.tsx"]
}
